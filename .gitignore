# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
*.egg
*.egg-info/
dist/
build/
wheels/

# Virtual environments
venv/
.venv/
env/
ENV/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Data (CRITICAL - never commit real financial data)
# User data should be in a separate private repository
# Only track example files and directory structure placeholders
data/

# Exports (generated reports contain financial data)
exports/

# Allow example files and directory structure
!data/.gitkeep
!data/examples/
!data/examples/**

# Metadata archives (Issue #62 - optional archiving)
# XLSX files copied to data/metadata/archives/ for reproducibility
# These contain personal financial data and should never be committed
**/metadata/archives/
**/metadata/archives/*.xlsx

# Database files (anywhere in project)
*.db
*.sqlite
*.sqlite3

# Config with sensitive info
.env
config.local.yaml
*.local.*

# Personal/local scratch dirs (underscore prefix)
_*/

# Logs
logs/
*.log

# OS
.DS_Store
Thumbs.db
.DS_Store?
._*
.Spotlight-V100
.Trashes

# Testing
.pytest_cache/
.coverage
coverage.xml
coverage.json
htmlcov/
.tox/

# Security scan reports generated by pip-audit and Bandit.
# CI regenerates and uploads these artifacts; the reviewed baseline is
# security/pip-audit-baseline.json.
audit-report.json
bandit-report.json

# MyPy
.mypy_cache/
.dmypy.json
dmypy.json

# Ruff
.ruff_cache/

# Jupyter
.ipynb_checkpoints/
*.ipynb

# Temporary files
.temp_*
temp_*

# Benchmark data (generated by scripts/benchmark_storage.py)
# Contains synthetic test data for performance testing
# DB files are large binaries and should be regenerated as needed
# Exception: README.md is tracked for documentation (Issue #70)
benchmark_data/*
!benchmark_data/README.md
homebrew-banksalad/
.playwright-mcp/
.mcp.json
.gstack/
.codex/
.serena/

# Claude Code transient runtime artifacts
.claude/settings.local.json
.claude/state/
.claude/scheduled_tasks.lock

# Stale docs (archive/plans — kept locally, removed from tracking)
docs/archive/
docs/plans/
