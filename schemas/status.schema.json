      "additionalProperties": true,
      "properties": {
        "definitions": {
          "additionalProperties": true,
          "properties": {
            "needs_review": {
              "type": "string"
            },
            "rule_matched": {
              "type": "string"
            },
            "suggestable_untagged": {
              "type": "string"
            },
            "uncategorized": {
              "type": "string"
            },
