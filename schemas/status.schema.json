            "type": "string"
          }
        },
        "required": [
          "signal",
          "message",
          "command"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "rules_file": {
      "additionalProperties": true,
      "properties": {
        "exists": {
          "type": "boolean"
        },
        "modified_at": {
          "type": [
            "string",
            "null"
          ]
        },
        "path": {
          "type": "string"
        }
      },
