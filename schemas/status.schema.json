          "enum": [
            "ok",
            "warning",
            "critical"
          ],
          "type": "string"
        }
      },
      "required": [
        "status",
        "reasons"
      ],
      "type": "object"
    },
    "last_import": {
      "additionalProperties": true,
      "properties": {
