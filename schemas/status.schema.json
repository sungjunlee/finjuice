          "type": "integer"
        },
        "untagged_count": {
          "type": "integer"
        },
        "untagged_merchants": {
          "items": {
            "additionalProperties": true,
            "properties": {
              "count": {
                "type": "integer"
              },
              "merchant": {
                "type": "string"
              }
