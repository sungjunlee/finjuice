{
  "$id": "rules_export.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "properties": {
    "_meta": {
      "$ref": "_meta.schema.json"
    },
    "rule_count": {
      "type": "integer"
    },
    "rules": {
      "items": {
        "additionalProperties": true,
        "properties": {
          "category": {
            "type": [
              "string",
              "null"
            ]
          },
          "fields": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "match": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "priority": {
            "type": "integer"
          },
          "tags": {
            "items": {
              "type": "string"
            },
            "type": "array"
          }
        },
        "required": [
          "name",
          "match",
          "fields",
          "tags",
          "category",
          "priority"
        ],
        "type": "object"
      },
      "type": "array"
    }
  },
  "required": [
    "_meta",
    "rule_count",
    "rules"
  ],
  "title": "rules export --json output",
  "type": "object"
}
