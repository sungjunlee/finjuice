# Git attributes for consistent line endings and diff behavior

# CSV partitions - text files with LF line endings
*.csv text eol=lf

# Ensure Python files have LF line endings
*.py text eol=lf
*.pyi text eol=lf

# Shell scripts
*.sh text eol=lf

# Markdown and documentation
*.md text eol=lf
*.txt text eol=lf

# YAML and JSON
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf

# Binary files (don't try to diff or merge)
*.db binary
*.sqlite binary
*.sqlite3 binary
*.xlsx binary
*.xls binary
*.pdf binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
